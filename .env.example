# ============================================================
# Heartisans Autonomous Data Pipeline — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.

# ---- LLM Configuration ----
# Supported providers: ollama, openai, anthropic, cerebras
LLM_PROVIDER=cerebras
LLM_FALLBACK=

# Cerebras Settings (Fast Llama inference — RECOMMENDED)
CEREBRAS_API_KEY=your_cerebras_api_key_here
CEREBRAS_MODEL=gpt-oss-120b

# Ollama Settings (local LLM — no API key needed)
OLLAMA_MODEL=llama3
OLLAMA_HOST=http://localhost:11434

# OpenAI Settings (optional)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Anthropic Settings (optional)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-haiku-20240307

# ---- Scraping Configuration ----
MIN_DELAY_SECONDS=2
MAX_DELAY_SECONDS=7
REQUEST_TIMEOUT=30
MAX_RETRIES=3

# Concurrent requests (Spider framework)
CONCURRENT_REQUESTS=5

# Circuit Breaker
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT=300

# ---- Currency ----
# All prices normalized to this currency (INR = Indian Rupees)
CURRENCY=INR

# ---- Database ----
DATABASE_PATH=./data/heartisans.db

# ---- Pipeline ----
TARGET_ROW_COUNT=10000
CHECKPOINT_INTERVAL=100

# ---- Logging ----
LOG_LEVEL=INFO
