# LLM Configuration
# Supported providers: ollama, openai, anthropic, cerebras
LLM_PROVIDER=cerebras
LLM_FALLBACK=

# Cerebras Settings (Fast Llama inference - RECOMMENDED)
CEREBRAS_API_KEY=your_cerebras_api_key_here
CEREBRAS_MODEL=llama3.3-70b

# Ollama Settings (if using local LLM)
OLLAMA_MODEL=llama3
OLLAMA_HOST=http://localhost:11434

# OpenAI Settings (optional alternative)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Anthropic Settings (optional alternative)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-haiku-20240307

# Scraping Configuration
MIN_DELAY_SECONDS=2
MAX_DELAY_SECONDS=7
REQUEST_TIMEOUT=30
MAX_RETRIES=3
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# Circuit Breaker
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT=300

# Database
DATABASE_PATH=./data/heartisans.db

# Pipeline Configuration
TARGET_ROW_COUNT=10000
CHECKPOINT_INTERVAL=100

# Logging
LOG_LEVEL=INFO
